# Birthday Bloom v3.0 environment template
# Copy this file to `.env.local`.
# All VITE_ values are public in the browser. Do not put secrets here.
# Normal customization should happen here or in your host's Environment Variables/Secrets panel.
# You do not need to edit React components just to change names, photos, messages, relationship type, sections, or family template details.

# Core identity
VITE_BIRTHDAY_NAME=Birthday Person
VITE_BIRTHDAY_AGE=25
VITE_BIRTHDAY_GENDER=other
VITE_BIRTHDAY_DATE=2026-04-24T00:00:00
VITE_BIRTHDAY_RELATIONSHIP=friend
VITE_BIRTHDAY_WISHER_NAME=Alex

# Message and theme
VITE_BIRTHDAY_CUSTOM_MESSAGE=Have the most amazing birthday ever!
VITE_BIRTHDAY_LETTER_TITLE=To My Favorite Person
VITE_BIRTHDAY_LETTER_OVERRIDE=Dear Birthday Star,\n\nToday is your day. Every moment with you matters.\n\nWith love,\nAlex
VITE_BIRTHDAY_COLOR=#FF6B6B
# Reserved for future theme hints; not currently parsed
# VITE_THEME=fun
VITE_BIRTHDAY_INTERESTS=Gaming,Music,Travel
VITE_FAVORITE_EMOJIS=party,sparkle,star

# Photos
# Use either VITE_PHOTOS for unlimited photos or VITE_PHOTO_1..6 for simple setup.
VITE_PHOTOS=
VITE_PHOTO_1=https://images.unsplash.com/photo-1530103043960-ef38714abb15?w=1200
VITE_PHOTO_2=https://images.unsplash.com/photo-1464349095431-e9a21285b5f3?w=1200
VITE_PHOTO_3=https://images.unsplash.com/photo-1513151233558-d860c5398176?w=1200
VITE_PHOTO_4=
VITE_PHOTO_5=
VITE_PHOTO_6=
VITE_PHOTO_CAPTIONS=Our favorite memory|A day worth keeping|The smile that says everything

# Videos and audio
VITE_VIDEO_1=
VITE_VIDEO_2=
VITE_VIDEO_3=
VITE_FINAL_VIDEO_URL=
VITE_SOUND_URL=https://assets.mixkit.co/active_storage/music/2869/2869-preview.mp3
VITE_BGM_URL=
# Reserved for future audio integration; not currently consumed by runtime
VITE_SONG_URL=
VITE_VOICE_MESSAGE_URL=
# Reserved for future sound control; not currently parsed
VITE_SOUND_EFFECTS=true

# Sections
VITE_SHOW_PHOTO_SECTION=true
VITE_SHOW_QUIZ_SECTION=true
VITE_SHOW_GIFT_SECTION=true
VITE_SHOW_HEART_TREE_SECTION=true
VITE_SHOW_VIDEO_SECTION=true
VITE_SHOW_CAKE_SECTION=true
VITE_SHOW_FINAL_SURPRISE=true
# Skip button is currently always shown; this env is reserved for future parsing
VITE_SHOW_SKIP_BUTTON=true

# Animation and accessibility
VITE_ANIMATION_SPEED=moderate
VITE_ANIMATION_INTENSITY=high
VITE_PARTICLE_COUNT=25
# Reserved for future reduced-motion support; not currently parsed
VITE_REDUCED_MOTION=false
# Reserved for future text scaling support; not currently parsed
VITE_TEXT_SIZE=normal
# Reserved for future high-contrast support; not currently parsed
VITE_HIGH_CONTRAST=false

# Special memories
# Format: Title;imageUrl|Title;imageUrl
VITE_SPECIAL_MEMORIES=First celebration;https://example.com/memory-1.jpg|Favorite trip;https://example.com/memory-2.jpg

# Family template entry point
# Supported: brother, sister, father, mother, grandfather, grandmother, uncle, aunt, cousin, son, daughter, guardian, friend, custom
VITE_FAMILY_MEMBER_TYPE=friend
VITE_FAMILY_PREFERRED_NAME=
VITE_FAMILY_NICKNAMES=
VITE_FAMILY_RELATIONSHIP_LABEL=
VITE_FAMILY_CLOSENESS=7
VITE_FAMILY_YEARS_KNOWN=
VITE_FAMILY_SIDE=unknown
VITE_FAMILY_PRIVACY=family
VITE_FAMILY_ALLOW_EXPORT=true

# Advanced family import
# Paste a full JSON FamilyMemberProfile when you need every schema field from env.
VITE_FAMILY_PROFILE_JSON=

# Cinematic password unlock (v3.1 features)
# Set VITE_PASSWORD_REQUIRED=true to enable password unlock screen.
# If VITE_PASSWORD is not set, the passcode is automatically generated from VITE_BIRTHDAY_DATE.
# Format options: MMDD (default), DDMM, YYYYMMDD, YYYY-MM-DD, MM-DD, DD-MM, YYYY.
VITE_PASSWORD_REQUIRED=false
VITE_PASSWORD=
VITE_PASSWORD_HINT=
VITE_PASSWORD_FORMAT=MMDD

# Debug and integrations
# Reserved for future debug logging support; not currently parsed
# VITE_DEBUG=false
# Reserved for future analytics integration; not currently parsed
# VITE_ANALYTICS_ID=
